void setup(){
  oddEven(20,11);
}

void oddEven(int x, int y){
 
  if(x%2 == 0)
  {
    println("First Number is Even");
  }
  else 
  {
    println("First Number is Odd");
  }
  
   if(y%2 == 0)
  {
    println("Second Number is Even");
  }
  else 
  {
    println("Second Number is Odd");
  }
}
